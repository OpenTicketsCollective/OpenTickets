# OpenTickets MySQL Database Configuration
# Copy this to .env and customize for your environment

# Root password for MySQL (required for first run)
MYSQL_ROOT_PASSWORD=RootPass123!

# Database credentials (from setup_mysql_users.sql)
# These users should be created after initial setup
# See DATABASE_SETUP.md for instructions

