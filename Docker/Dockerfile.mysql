# OpenTickets MySQL Database
# Based on Docker Hardened Image (DHI) - MySQL 8.4.x
# See: https://docs.docker.com/dhi/

FROM dhi/mysql:8.4.8-debian13

# Copy initialization schema
COPY Docker/init-schema.sql /docker-entrypoint-initdb.d/01-init-schema.sql

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
  CMD mysql -u root -e 'SELECT 1' || exit 1

EXPOSE 3306
